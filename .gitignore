# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit local secrets)
.env*
!.env.example
*.json.key
*service-account*.json
*listingstream-key*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
services/launchpad-service/__pycache__/
*.pyc
